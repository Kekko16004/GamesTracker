# GamesTracker — environment variables example
# Copy this file to config/.env and fill in your values.
# config/.env must NEVER be committed to version control.

# =============================================================================
# CORE DATA SOURCE API KEYS
# =============================================================================

# Steam Web API key (optional — enables player count tracking)
# Get it free at: https://steamcommunity.com/dev/apikey
# Requires a Steam account with at least one purchase.
# Without this key, the collector degrades gracefully (no player count).
STEAM_WEB_API_KEY=

# YouTube Data API v3 (required for YouTube source)
# Get it free at: Google Cloud Console → enable "YouTube Data API v3"
# Free quota: 10,000 units/day. 1 search = 100 units; 1 stats fetch = 1 unit.
YOUTUBE_API_KEY=

# Reddit OAuth credentials (required for Reddit source)
# Create a "script" type app at: https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
# Format: AppName/version by u/your_username
REDDIT_USER_AGENT=GamesTracker/2.0 by u/your_username

# RAWG Game Database API key (optional — enriches game metadata)
# Get it free at: https://rawg.io/apidocs (20,000 requests/month on free tier)
RAWG_API_KEY=

# IGDB (Twitch) credentials (required for IGDB source)
# IGDB is owned by Twitch — create a Twitch app at: https://dev.twitch.tv/console
# Both values are needed; the collector exchanges them for a Bearer token automatically.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# =============================================================================
# SOCIAL SCRAPING
# =============================================================================

# Master switch for the automated social scraping engine.
# false = scrapers defined but disabled (default — ToS-safe, manual import still works)
# true  = scrapers run automatically on the configured interval
SCRAPING_ENABLED=false

# How often the social scraping cycle runs (hours)
SCRAPING_INTERVAL_HOURS=6

# Nitter instance for X/Twitter scraping (no-auth approach)
# For reliability, run your own: https://github.com/zedeus/nitter
# Public instances (e.g. nitter.net) may be unreliable.
NITTER_INSTANCE=https://nitter.net

# HTTP proxy for all social scraper traffic (optional)
# Reduces rate-limit risk for TikTok, Instagram, X scrapers.
# Format: http://user:pass@host:port  OR  socks5://host:port
PROXY_URL=

# =============================================================================
# NOTIFICATIONS
# =============================================================================

# Master switch for all notifications
NOTIFICATIONS_ENABLED=false

# Discord webhook URL for alerts (viral detection, score threshold crossed, etc.)
# Create at: Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=

# Telegram bot credentials for alerts
# Create a bot via @BotFather, then get the chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# =============================================================================
# DATABASE
# =============================================================================

# SQLAlchemy database URL.
# Default: SQLite in data/gamestracker.db (auto-created on first run)
# For PostgreSQL: postgresql+psycopg://user:password@host:5432/gamestracker
DB_URL=

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Default UI and report language: it (Italian) | en (English)
# Can also be switched at runtime via the GUI Language menu.
APP_LANG=it

# Quality score threshold (0–100).
# Games below this score are filtered as "trash" in the GUI by default.
# The user can override this with the dashboard slider.
QUALITY_SCORE_THRESHOLD=40

# How often the collector scans for new game releases (hours)
DISCOVERY_INTERVAL_HOURS=6

# Port for the FastAPI web dashboard
WEB_PORT=8080

# Identifies the app in all outgoing HTTP requests (ToS compliance).
# Use a URL that points to this project.
HTTP_USER_AGENT=GamesTracker/2.0 (+https://github.com/Kekko16004/GamesTracker)
