 {% block scripts %}
+<script>
+function enrichmentPanel() {
+  return {
+    data: null,
+    loading: true,
+    error: '',
+    async load() {
+      try {
+        const resp = await fetch('/api/game/{{ game.id }}/enrich');
+        if (!resp.ok) throw new Error('Failed to load');
+        this.data = await resp.json();
+      } catch(e) {
+        this.error = 'Could not load live market data';
+      } finally {
+        this.loading = false;
+      }
+    },
+    formatOwners(n) {
+      if (n >= 1000000) return (n / 1000000).toFixed(2) + 'M';
+      if (n >= 1000) return (n / 1000).toFixed(1) + 'K';
+      return n.toString();
+    }
+  }
+}
+</script>
